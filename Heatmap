function renderHeatCal(){
  // build date map
  const dm={};
  for(const sub of Object.values(state.subjects)){
    for(const[dk,sess]of Object.entries(sub.sessions)){
      const m=dk.match(/(\d{1,2})\/(\d{2})/);if(!m)continue;
      const key=`${m[2]}/${m[1].padStart(2,'0')}`;
      if(!dm[key])dm[key]={done:0,total:0};
      dm[key].done+=sp(sess);dm[key].total+=3;
    }
  }
  const months=['Nov','Dec','Jan','Feb','Mar','Apr'];
  const mNums=[11,12,1,2,3,4];
  const yr=m=>m<=4?2025:2024;
  const grid=document.getElementById('calGrid');
  grid.innerHTML='';
  document.getElementById('calML').innerHTML=months.map(m=>`<span>${m}</span>`).join('');
  let allDays=[];
  for(let mi=0;mi<mNums.length;mi++){
    const m=mNums[mi],y=yr(m),dim=new Date(y,m,0).getDate();
    for(let d=1;d<=dim;d++)allDays.push({m,d,y,key:`${String(m).padStart(2,'0')}/${String(d).padStart(2,'0')}`});
  }
  const firstDow=(new Date(2024,10,1).getDay()+6)%7;
  for(let i=0;i<firstDow;i++){const c=document.createElement('div');c.className='cal-cell';c.style.background='transparent';c.style.cursor='default';grid.appendChild(c);}
  for(const day of allDays){
    const info=dm[day.key];
    const cell=document.createElement('div');cell.className='cal-cell';
    if(!info){cell.style.background='var(--surface3)';}
    else{const a=0.12+(info.done/info.total)*0.88;cell.style.background=`rgba(124,106,247,${a.toFixed(2)})`;}
    const mn=months[mNums.indexOf(day.m)];
    const tip=info?`${mn} ${day.d} · ${info.done}/${info.total} tasks (${Math.round(info.done/info.total*100)}%)`:`${mn} ${day.d} · no class`;
    cell.innerHTML=`<div class="ctip">${tip}</div>`;
    grid.appendChild(cell);
  }
}

function renderRadar(){
  const svg=document.getElementById('radarSvg');svg.innerHTML='';
  const entries=Object.entries(state.subjects);const N=entries.length;
  const cx=95,cy=88,R=68;
  const angles=entries.map((_,i)=>(i/N)*Math.PI*2-Math.PI/2);
  for(let r=0.25;r<=1;r+=0.25){
    const pts=angles.map(a=>`${cx+R*r*Math.cos(a)},${cy+R*r*Math.sin(a)}`).join(' ');
    const poly=document.createElementNS('http://www.w3.org/2000/svg','polygon');
    poly.setAttribute('points',pts);poly.setAttribute('fill','none');
    poly.setAttribute('stroke','rgba(42,42,58,.8)');poly.setAttribute('stroke-width','1');
    svg.appendChild(poly);
  }
  const dpts=entries.map(([,sub],i)=>{
    const st=sStat(sub),r=1-(st.pct/100);
    return `${cx+R*r*Math.cos(angles[i])},${cy+R*r*Math.sin(angles[i])}`;
  }).join(' ');
  const poly=document.createElementNS('http://www.w3.org/2000/svg','polygon');
  poly.setAttribute('points',dpts);poly.setAttribute('fill','rgba(247,162,106,.14)');
  poly.setAttribute('stroke','var(--accent2)');poly.setAttribute('stroke-width','1.5');svg.appendChild(poly);
  entries.forEach(([name],i)=>{
    const ax=cx+(R+13)*Math.cos(angles[i]),ay=cy+(R+13)*Math.sin(angles[i]);
    const t=document.createElementNS('http://www.w3.org/2000/svg','text');
    t.setAttribute('x',ax);t.setAttribute('y',ay);t.setAttribute('text-anchor','middle');t.setAttribute('dominant-baseline','middle');
    t.setAttribute('fill','#6a6a8a');t.setAttribute('font-size','6');t.setAttribute('font-family','JetBrains Mono,monospace');
    t.textContent=name.length>9?name.slice(0,9)+'…':name;svg.appendChild(t);
  });
  const note=document.createElementNS('http://www.w3.org/2000/svg','text');
  note.setAttribute('x',95);note.setAttribute('y',171);note.setAttribute('text-anchor','middle');
  note.setAttribute('fill','rgba(106,106,138,.5)');note.setAttribute('font-size','6');note.setAttribute('font-family','JetBrains Mono,monospace');
  note.textContent='Larger area = more backlog';svg.appendChild(note);
}

