}

function renderDonut(){
  let nD=0,vD=0,dbD=0,tS=0;
  for(const sub of Object.values(state.subjects)){const st=sStat(sub);nD+=st.notes;vD+=st.video;dbD+=st.doubts;tS+=st.sessions;}
  const pend=tS*3-nD-vD-dbD;
  const data=[
    {l:'Notes',v:nD,c:'#6aabf7'},{l:'Video',v:vD,c:'#f7d06a'},
    {l:'Doubts',v:dbD,c:'#b06af7'},{l:'Pending',v:pend,c:'#1e1e2e'}
  ];
  const total=data.reduce((a,d)=>a+d.v,0)||1;
  const svg=document.getElementById('donutSvg');svg.innerHTML='';
  const cx=54,cy=54,r=38,sw=16;let cum=0;
  for(const d of data){
    const pct=d.v/total;if(pct<0.001){cum+=pct;continue;}
    const s=cum*Math.PI*2-Math.PI/2,e=(cum+pct)*Math.PI*2-Math.PI/2;
    const x1=cx+r*Math.cos(s),y1=cy+r*Math.sin(s),x2=cx+r*Math.cos(e),y2=cy+r*Math.sin(e);
    const la=pct>0.5?1:0;
    const path=document.createElementNS('http://www.w3.org/2000/svg','path');
    path.setAttribute('d',`M ${x1} ${y1} A ${r} ${r} 0 ${la} 1 ${x2} ${y2}`);
    path.setAttribute('fill','none');path.setAttribute('stroke',d.c);
    path.setAttribute('stroke-width',sw);path.setAttribute('stroke-linecap','butt');
    svg.appendChild(path);cum+=pct;
  }
  const pctDone=Math.round((nD+vD+dbD)/total*100);
  const t1=document.createElementNS('http://www.w3.org/2000/svg','text');
  t1.setAttribute('x',cx);t1.setAttribute('y',cy+1);t1.setAttribute('text-anchor','middle');
  t1.setAttribute('fill','#e4e4f0');t1.setAttribute('font-size','13');t1.setAttribute('font-weight','700');
  t1.setAttribute('font-family','Syne,sans-serif');t1.textContent=`${pctDone}%`;
  const t2=document.createElementNS('http://www.w3.org/2000/svg','text');
  t2.setAttribute('x',cx);t2.setAttribute('y',cx+11);t2.setAttribute('text-anchor','middle');
  t2.setAttribute('fill','#6a6a8a');t2.setAttribute('font-size','6.5');t2.setAttribute('font-family','JetBrains Mono,monospace');
  t2.textContent='done';svg.appendChild(t1);svg.appendChild(t2);
  document.getElementById('donutLeg').innerHTML=data.map(d=>`
    <div class="donut-item"><div class="donut-sw" style="background:${d.c}"></div>${d.l}: <b>${d.v}</b></div>`).join('');
}

