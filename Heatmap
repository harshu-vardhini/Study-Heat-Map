<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UPSC Study Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#07070d;--surface:#0f0f18;--surface2:#171724;--surface3:#1e1e2e;
  --border:#252535;--accent:#7c6af7;--accent2:#f7a26a;--accent3:#6af7c0;
  --text:#e4e4f0;--text-dim:#6a6a8a;--danger:#f76a6a;
  --notes:#6aabf7;--video:#f7d06a;--doubts:#b06af7;--done:#6af7a0;
  --sidebar-w:228px;--header-h:52px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--text);font-family:'JetBrains Mono',monospace;display:flex;flex-direction:column;}
body::before{content:'';position:fixed;inset:0;
  background-image:linear-gradient(rgba(124,106,247,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(124,106,247,.025) 1px,transparent 1px);
  background-size:48px 48px;pointer-events:none;z-index:0;}

/* HEADER */
.header{position:relative;z-index:200;height:var(--header-h);
  background:rgba(7,7,13,.96);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:12px;padding:0 16px;flex-shrink:0;}
.burger{width:32px;height:32px;border-radius:7px;border:1px solid var(--border);
  background:transparent;cursor:pointer;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:4px;flex-shrink:0;transition:background .15s;}
.burger:hover{background:var(--surface2);}
.burger span{display:block;width:15px;height:1.5px;background:var(--text-dim);border-radius:2px;transition:all .25s;}
.burger.open span:nth-child(1){transform:translateY(5.5px) rotate(45deg);}
.burger.open span:nth-child(2){opacity:0;}
.burger.open span:nth-child(3){transform:translateY(-5.5px) rotate(-45deg);}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.05rem;letter-spacing:.06em;color:var(--accent);white-space:nowrap;}
.logo em{color:var(--text-dim);font-style:normal;font-weight:400;font-size:.68rem;margin-left:7px;}
.header-pills{display:flex;gap:7px;flex-wrap:nowrap;overflow:hidden;flex:1;}
.pill{background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:3px 10px;font-size:.62rem;color:var(--text-dim);white-space:nowrap;}
.pill b{color:var(--text);font-weight:500;}
.pill.hl{border-color:rgba(124,106,247,.4);color:var(--accent);}
.hdr-right{display:flex;gap:6px;flex-shrink:0;}
.btn{font-family:'JetBrains Mono',monospace;font-size:.65rem;padding:5px 11px;border-radius:7px;border:1px solid var(--border);cursor:pointer;transition:all .15s;white-space:nowrap;}
.btn-primary{background:var(--accent);color:#fff;border-color:var(--accent);}
.btn-primary:hover{background:#6a58e0;}
.btn-ghost{background:transparent;color:var(--text-dim);}
.btn-ghost:hover{background:var(--surface2);color:var(--text);}
.btn-green{background:transparent;color:var(--accent3);border-color:rgba(106,247,192,.3);}
.btn-green:hover{background:rgba(106,247,192,.07);}
.btn-orange{background:transparent;color:var(--accent2);border-color:rgba(247,162,106,.3);}
.btn-orange:hover{background:rgba(247,162,106,.07);}

/* LAYOUT */
.app-body{display:flex;flex:1;overflow:hidden;position:relative;z-index:1;}

/* SIDEBAR */
.sidebar{width:var(--sidebar-w);flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);
  display:flex;flex-direction:column;overflow:hidden;transition:width .25s cubic-bezier(.4,0,.2,1),opacity .2s;}
.sidebar.closed{width:0;opacity:0;pointer-events:none;}
.sidebar-inner{width:var(--sidebar-w);display:flex;flex-direction:column;height:100%;overflow-y:auto;overflow-x:hidden;}
.sidebar-sec{padding:13px 13px 5px;font-size:.56rem;letter-spacing:.1em;color:var(--text-dim);text-transform:uppercase;}
.nav-item{display:flex;align-items:center;gap:9px;padding:7px 13px;cursor:pointer;
  font-size:.68rem;color:var(--text-dim);transition:background .12s,color .12s;
  border-left:2px solid transparent;user-select:none;}
.nav-item:hover{background:var(--surface2);color:var(--text);}
.nav-item.active{background:rgba(124,106,247,.1);color:var(--accent);border-left-color:var(--accent);}
.nav-icon{font-size:.85rem;width:18px;text-align:center;flex-shrink:0;}
.nav-badge{margin-left:auto;background:var(--surface3);border-radius:10px;padding:1px 7px;font-size:.58rem;color:var(--text-dim);}
.nav-badge.warn{color:var(--accent2);}
.sdiv{height:1px;background:var(--border);margin:7px 13px;}
.sidebar-foot{margin-top:auto;padding:11px 13px;border-top:1px solid var(--border);}
.save-ind{font-size:.58rem;color:var(--text-dim);display:flex;align-items:center;gap:6px;}
.save-dot{width:6px;height:6px;border-radius:50%;background:var(--done);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3};}

/* MAIN */
.main{flex:1;overflow-y:auto;overflow-x:hidden;display:flex;flex-direction:column;}
.view{display:none;padding:18px;animation:fadeIn .2s ease;}
.view.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(5px);}to{opacity:1;transform:translateY(0);}}

/* ANALYTICS */
.stat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));gap:9px;margin-bottom:16px;}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:13px 14px;}
.stat-label{font-size:.56rem;color:var(--text-dim);letter-spacing:.08em;text-transform:uppercase;margin-bottom:7px;}
.stat-val{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;line-height:1;}
.stat-sub{font-size:.58rem;color:var(--text-dim);margin-top:4px;}

.charts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:13px;}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:15px;}
.chart-card h4{font-family:'Syne',sans-serif;font-size:.72rem;font-weight:700;color:var(--text-dim);
  letter-spacing:.06em;margin-bottom:13px;text-transform:uppercase;}
.chart-card.wide{grid-column:1/-1;}

/* Subject bar chart */
.bar-chart{display:flex;flex-direction:column;gap:6px;}
.bar-row{display:flex;align-items:center;gap:7px;}
.bar-label{font-size:.6rem;color:var(--text-dim);width:105px;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.bar-track{flex:1;height:13px;background:var(--surface3);border-radius:4px;overflow:visible;display:flex;position:relative;cursor:pointer;}
.bar-seg{height:100%;transition:width .5s cubic-bezier(.4,0,.2,1);}
.bar-seg.n{background:var(--notes);}
.bar-seg.v{background:var(--video);}
.bar-seg.d{background:var(--doubts);}
.bar-pct{font-size:.58rem;color:var(--text-dim);width:30px;text-align:right;flex-shrink:0;}
.bar-tip{display:none;position:absolute;bottom:calc(100%+5px);left:50%;transform:translateX(-50%);
  background:var(--surface2);border:1px solid var(--border);border-radius:6px;
  padding:5px 9px;font-size:.6rem;color:var(--text);z-index:20;white-space:nowrap;pointer-events:none;}
.bar-track:hover .bar-tip{display:block;}

/* Donut */
.donut-wrap{display:flex;align-items:center;gap:18px;flex-wrap:wrap;}
.donut-legend{display:flex;flex-direction:column;gap:7px;}
.donut-item{display:flex;align-items:center;gap:7px;font-size:.63rem;color:var(--text-dim);}
.donut-sw{width:9px;height:9px;border-radius:3px;flex-shrink:0;}
.donut-item b{color:var(--text);font-weight:500;}

/* Task radial */
.rad-row{display:flex;align-items:center;gap:9px;margin-bottom:9px;}
.rad-lbl{font-size:.62rem;color:var(--text-dim);width:56px;}
.rad-bar{flex:1;height:7px;background:var(--surface3);border-radius:4px;overflow:hidden;}
.rad-fill{height:100%;border-radius:4px;transition:width .6s cubic-bezier(.4,0,.2,1);}
.rad-val{font-size:.6rem;color:var(--text-dim);width:38px;text-align:right;}

/* Heat cal */
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;}
.cal-cell{aspect-ratio:1;border-radius:3px;cursor:pointer;position:relative;transition:transform .1s;}
.cal-cell:hover{transform:scale(1.25);z-index:5;}
.cal-cell .ctip{display:none;position:absolute;bottom:calc(100%+4px);left:50%;transform:translateX(-50%);
  background:var(--surface2);border:1px solid var(--border);border-radius:5px;padding:4px 8px;
  font-size:.57rem;white-space:nowrap;z-index:20;color:var(--text);pointer-events:none;}
.cal-cell:hover .ctip{display:block;}
.cal-mlabels{display:flex;justify-content:space-between;font-size:.56rem;color:var(--text-dim);margin-bottom:4px;}
.heat-legend{display:flex;gap:7px;margin-top:7px;align-items:center;font-size:.56rem;color:var(--text-dim);}

/* Behind list */
.behind-row{display:flex;align-items:center;gap:7px;margin-bottom:5px;}
.behind-bar{flex:1;height:4px;background:var(--surface3);border-radius:2px;overflow:hidden;margin-bottom:8px;}
.behind-fill{height:100%;border-radius:2px;transition:width .5s;}

/* TRACKER */
.toolbar{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px;align-items:center;}
.toolbar select,.toolbar input{background:var(--surface2);border:1px solid var(--border);color:var(--text);
  font-family:'JetBrains Mono',monospace;font-size:.65rem;padding:5px 8px;border-radius:6px;outline:none;}
.toolbar select:focus,.toolbar input:focus{border-color:var(--accent);}
.toolbar input{width:148px;}
.overall-tag{margin-left:auto;font-size:.65rem;color:var(--text-dim);}
.overall-tag b{color:var(--accent);}
.leg-row{display:flex;gap:12px;flex-wrap:wrap;font-size:.6rem;color:var(--text-dim);margin-bottom:13px;align-items:center;}
.leg{display:flex;align-items:center;gap:4px;}
.leg-dot{width:8px;height:8px;border-radius:3px;}

.subjects-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(330px,1fr));gap:13px;}
.subject-card{background:var(--surface);border:1px solid var(--border);border-radius:11px;overflow:hidden;transition:border-color .2s;}
.subject-card:hover{border-color:rgba(124,106,247,.35);}
.card-hdr{padding:11px 13px 9px;display:flex;align-items:center;gap:8px;cursor:pointer;user-select:none;}
.card-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.card-name{font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;letter-spacing:.04em;flex:1;}
.card-meta{font-size:.58rem;color:var(--text-dim);white-space:nowrap;}
.card-tog{color:var(--text-dim);font-size:.72rem;transition:transform .2s;}
.subject-card.collapsed .card-tog{transform:rotate(-90deg);}
.card-bar{height:3px;background:var(--border);display:flex;overflow:hidden;}
.card-seg{height:100%;transition:width .4s;}
.sess-list{display:block;}
.subject-card.collapsed .sess-list,.subject-card.collapsed .add-row{display:none;}
.sess-row{display:grid;grid-template-columns:1fr auto auto auto auto;align-items:center;gap:6px;
  padding:7px 13px;border-bottom:1px solid rgba(37,37,53,.7);transition:background .1s;}
.sess-row:last-child{border-bottom:none;}
.sess-row:hover{background:var(--surface2);}
.sess-row.all-done{opacity:.42;}
.sess-date{font-size:.65rem;color:var(--text);}
.sess-snip{display:block;font-size:.55rem;color:var(--text-dim);font-style:italic;margin-top:2px;
  max-width:140px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;}
.chk{width:24px;height:24px;border-radius:6px;border:1.5px solid var(--border);background:transparent;
  cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.65rem;
  transition:all .12s;flex-shrink:0;position:relative;}
.chk:hover{border-color:var(--text-dim);}
.chk[data-t="notes"].on{background:rgba(106,171,247,.15);border-color:var(--notes);color:var(--notes);}
.chk[data-t="video"].on{background:rgba(247,208,106,.15);border-color:var(--video);color:var(--video);}
.chk[data-t="doubts"].on{background:rgba(176,106,247,.15);border-color:var(--doubts);color:var(--doubts);}
.chk .tip{display:none;position:absolute;bottom:calc(100%+3px);left:50%;transform:translateX(-50%);
  background:var(--surface2);border:1px solid var(--border);font-size:.56rem;color:var(--text-dim);
  padding:2px 6px;border-radius:4px;white-space:nowrap;z-index:10;pointer-events:none;}
.chk:hover .tip{display:block;}
.sact{display:flex;gap:3px;}
.ico{background:transparent;border:none;color:var(--text-dim);cursor:pointer;font-size:.65rem;
  padding:3px 4px;border-radius:4px;line-height:1;transition:color .12s,background .12s;}
.ico:hover{color:var(--text);background:var(--surface2);}
.ico.del:hover{color:var(--danger);}
.add-row{padding:7px 13px;display:flex;gap:5px;align-items:center;border-top:1px solid var(--border);background:rgba(124,106,247,.02);}
.add-row input{flex:1;background:var(--surface2);border:1px solid var(--border);color:var(--text);
  font-family:'JetBrains Mono',monospace;font-size:.62rem;padding:5px 7px;border-radius:5px;outline:none;}
.add-row input:focus{border-color:var(--accent);}
.add-row input::placeholder{color:var(--text-dim);}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:500;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:22px;width:390px;max-width:95vw;}
.modal h3{font-family:'Syne',sans-serif;font-size:.9rem;font-weight:700;margin-bottom:15px;color:var(--accent);}
.modal label{font-size:.62rem;color:var(--text-dim);display:block;margin-bottom:4px;}
.modal input,.modal select,.modal textarea{width:100%;background:var(--surface2);border:1px solid var(--border);color:var(--text);
  font-family:'JetBrains Mono',monospace;font-size:.7rem;padding:7px 9px;border-radius:7px;outline:none;margin-bottom:11px;resize:vertical;}
.modal input:focus,.modal select:focus,.modal textarea:focus{border-color:var(--accent);}
.modal-act{display:flex;gap:7px;justify-content:flex-end;margin-top:4px;}

/* TOAST */
.toast{position:fixed;bottom:18px;right:18px;background:var(--surface2);border:1px solid var(--accent);color:var(--text);
  font-size:.65rem;padding:8px 15px;border-radius:8px;z-index:999;opacity:0;transform:translateY(7px);transition:all .2s;pointer-events:none;}
.toast.show{opacity:1;transform:translateY(0);}

::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
::-webkit-scrollbar-thumb:hover{background:#3a3a52;}

@media(max-width:640px){
  .sidebar{position:fixed;top:var(--header-h);left:0;bottom:0;z-index:150;}
  .sidebar.closed{width:0;}
  .header-pills{display:none;}
  .logo em{display:none;}
}
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <button class="burger" id="burgerBtn" onclick="toggleSidebar()">
    <span></span><span></span><span></span>
  </button>
  <div class="logo">UPSC <em>// tracker</em></div>
  <div class="header-pills" id="hPills"></div>
  <div class="hdr-right">
    <button class="btn btn-orange" onclick="openAddSubject()">+ Subject</button>
    <button class="btn btn-green" onclick="exportCSV()">↓ CSV</button>
    <button class="btn btn-primary" onclick="saveData()">⬡ Save</button>
  </div>
</div>

<!-- APP BODY -->
<div class="app-body">
  <!-- SIDEBAR -->
  <div class="sidebar" id="sidebar">
    <div class="sidebar-inner">
      <div class="sidebar-sec">Views</div>
      <div class="nav-item active" data-view="analytics" onclick="switchView('analytics',this)">
        <span class="nav-icon">◈</span> Analytics
      </div>
      <div class="nav-item" data-view="tracker" onclick="switchView('tracker',this)">
        <span class="nav-icon">☰</span> All Sessions
      </div>
      <div class="sdiv"></div>
      <div class="sidebar-sec">Jump to Subject</div>
      <div id="subNav"></div>
      <div class="sdiv"></div>
      <div class="sidebar-sec">Actions</div>
      <div class="nav-item" onclick="exportCSV()"><span class="nav-icon">↓</span> Export CSV</div>
      <div class="nav-item" onclick="triggerImport()"><span class="nav-icon">↑</span> Import CSV</div>
      <input type="file" id="csvFile" accept=".csv" style="display:none" onchange="handleImport(event)">
      <div class="nav-item" onclick="collapseAll()"><span class="nav-icon">⊟</span> Collapse All</div>
      <div class="nav-item" onclick="expandAll()"><span class="nav-icon">⊞</span> Expand All</div>
      <div class="sidebar-foot">
        <div class="save-ind"><span class="save-dot"></span> Auto-saves every 30s</div>
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main" id="mainArea">

    <!-- ANALYTICS VIEW -->
    <div class="view active" id="view-analytics">
      <div class="stat-grid" id="statGrid"></div>
      <div class="charts-grid">
        <div class="chart-card wide">
          <h4>Subject Progress — Notes · Video · Doubts</h4>
          <div class="bar-chart" id="subjectBars"></div>
        </div>
        <div class="chart-card">
          <h4>Overall Task Split</h4>
          <div class="donut-wrap">
            <svg id="donutSvg" width="108" height="108" viewBox="0 0 108 108"></svg>
            <div class="donut-legend" id="donutLeg"></div>
          </div>
        </div>
        <div class="chart-card">
          <h4>Task Type Completion</h4>
          <div id="taskBreak"></div>
        </div>
        <div class="chart-card wide">
          <h4>Session Heat Map (Nov 2024 – Apr 2025)</h4>
          <div class="cal-mlabels" id="calML"></div>
          <div class="cal-grid" id="calGrid"></div>
          <div class="heat-legend">
            <span>Less</span>
            <div style="display:flex;gap:2px;">
              <div style="width:9px;height:9px;border-radius:2px;background:var(--surface3)"></div>
              <div style="width:9px;height:9px;border-radius:2px;background:rgba(124,106,247,.2)"></div>
              <div style="width:9px;height:9px;border-radius:2px;background:rgba(124,106,247,.45)"></div>
              <div style="width:9px;height:9px;border-radius:2px;background:rgba(124,106,247,.7)"></div>
              <div style="width:9px;height:9px;border-radius:2px;background:var(--accent)"></div>
            </div>
            <span>More done</span>
          </div>
        </div>
        <div class="chart-card">
          <h4>Backlog Radar</h4>
          <svg id="radarSvg" width="190" height="175" viewBox="0 0 190 175" style="display:block;margin:0 auto;"></svg>
        </div>
        <div class="chart-card">
          <h4>Top 5 — Most Behind</h4>
          <div id="behindList"></div>
        </div>
      </div>
    </div>

    <!-- TRACKER VIEW -->
    <div class="view" id="view-tracker">
      <div class="toolbar">
        <label style="font-size:.62rem;color:var(--text-dim);">Filter:</label>
        <select id="fSub" onchange="renderTracker()"><option value="">All Subjects</option></select>
        <select id="fStatus" onchange="renderTracker()">
          <option value="">All Status</option>
          <option value="complete">Fully Done</option>
          <option value="partial">Partial</option>
          <option value="pending">Not Started</option>
        </select>
        <input id="fSearch" placeholder="Search dates..." oninput="renderTracker()" style="width:145px">
        <div class="overall-tag" id="overallTag"></div>
      </div>
      <div class="leg-row">
        <span style="font-size:.58rem;color:var(--text-dim)">MARK:</span>
        <div class="leg"><div class="leg-dot" style="background:var(--notes)"></div>📝 Notes</div>
        <div class="leg"><div class="leg-dot" style="background:var(--video)"></div>▶ Video</div>
        <div class="leg"><div class="leg-dot" style="background:var(--doubts)"></div>❓ Doubts</div>
        <div class="leg" style="margin-left:6px"><div class="leg-dot" style="background:var(--done)"></div>All done = faded</div>
      </div>
      <div class="subjects-grid" id="sGrid"></div>
    </div>

  </div>
</div>

<!-- MODALS -->
<div class="modal-overlay" id="addSubModal">
  <div class="modal">
    <h3>+ Add Subject</h3>
    <label>Subject Name</label>
    <input id="nSubName" placeholder="e.g. Ancient History">
    <label>Color</label>
    <input id="nSubColor" type="color" value="#7c6af7" style="height:32px;padding:2px 6px">
    <label>Paste dates (one per line)</label>
    <textarea id="nSubDates" rows="5" placeholder="04/02&#10;05/02 (1st Session)"></textarea>
    <div class="modal-act">
      <button class="btn btn-ghost" onclick="closeModal('addSubModal')">Cancel</button>
      <button class="btn btn-primary" onclick="addSubject()">Add</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="noteModal">
  <div class="modal" style="width:330px;">
    <h3 id="noteTitle">Session Note</h3>
    <textarea id="noteText" placeholder="Add a note..." rows="4"></textarea>
    <div class="modal-act">
      <button class="btn btn-ghost" onclick="closeModal('noteModal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveNote()">Save</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ── DATA ────────────────────────────────────────────────────────────────────
