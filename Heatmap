let state={subjects:{}};
let sidebarOpen=true;
let activeView='analytics';
let noteCtx={};

function initState(){
  const saved=localStorage.getItem('upsc_v4');
  if(saved){try{state=JSON.parse(saved);}catch(e){}}
  for(const[sub,dates]of Object.entries(RAW)){
    if(!state.subjects[sub])state.subjects[sub]={color:COLORS[sub]||'#7c6af7',collapsed:false,sessions:{}};
    for(const d of dates)if(!state.subjects[sub].sessions[d])state.subjects[sub].sessions[d]={notes:false,video:false,doubts:false,sessionNote:''};
  }
}
function saveData(){localStorage.setItem('upsc_v4',JSON.stringify(state));showToast('Saved ✓');}
setInterval(()=>localStorage.setItem('upsc_v4',JSON.stringify(state)),30000);

// HELPERS
function sp(s){return(s.notes?1:0)+(s.video?1:0)+(s.doubts?1:0);}
function sStat(sub){
  const ss=Object.values(sub.sessions);
  const total=ss.length*3,done=ss.reduce((a,s)=>a+sp(s),0);
  return{done,total,sessions:ss.length,notes:ss.filter(s=>s.notes).length,
    video:ss.filter(s=>s.video).length,doubts:ss.filter(s=>s.doubts).length,
    pct:total?Math.round(done/total*100):0};
}
function pdk(k){const m=k.match(/(\d{1,2})\/(\d{2})/);if(!m)return 9999;return parseInt(m[2])*100+parseInt(m[1]);}
function esc(n){return n.replace(/[^a-zA-Z0-9]/g,'_');}
function enc(d){return encodeURIComponent(d);}
function dec(d){return decodeURIComponent(d);}
function byEsc(e){return Object.keys(state.subjects).find(n=>esc(n)===e);}

// SIDEBAR
function toggleSidebar(){
  sidebarOpen=!sidebarOpen;
  document.getElementById('sidebar').classList.toggle('closed',!sidebarOpen);
  document.getElementById('burgerBtn').classList.toggle('open',sidebarOpen);
}
function switchView(name,el){
  activeView=name;
  document.querySelectorAll('.nav-item[data-view]').forEach(n=>n.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById('view-'+name).classList.add('active');
  document.getElementById('mainArea').scrollTop=0;
  if(name==='analytics')renderAnalytics();
  if(name==='tracker')renderTracker();
}
function buildSubNav(){
  const nav=document.getElementById('subNav');
  nav.innerHTML='';
  for(const[name,sub]of Object.entries(state.subjects)){
    const st=sStat(sub);
    const el=document.createElement('div');
    el.className='nav-item';
    el.innerHTML=`<span class="nav-icon" style="color:${sub.color}">●</span>
      <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${name}</span>
      <span class="nav-badge ${st.pct<50?'warn':''}">${st.pct}%</span>`;
    el.onclick=()=>{
      switchView('tracker',document.querySelector('[data-view="tracker"]'));
      document.getElementById('fSub').value=name;renderTracker();
    };
    nav.appendChild(el);
  }
}

// HEADER PILLS
function updatePills(){
  let tD=0,tA=0,tS=0,dS=0;
  for(const sub of Object.values(state.subjects)){const st=sStat(sub);tD+=st.done;tA+=st.total;tS+=st.sessions;dS+=Object.values(sub.sessions).filter(s=>sp(s)===3).length;}
  const pct=tA?Math.round(tD/tA*100):0;
  document.getElementById('hPills').innerHTML=`
    <div class="pill hl"><b>${pct}%</b> overall</div>
    <div class="pill">Sessions: <b>${dS}/${tS}</b></div>
    <div class="pill">Subjects: <b>${Object.keys(state.subjects).length}</b></div>`;
}

