function renderStatCards(){
  let tD=0,tA=0,tS=0,dS=0,nD=0,vD=0,dbD=0;
  for(const sub of Object.values(state.subjects)){
    const st=sStat(sub);tD+=st.done;tA+=st.total;tS+=st.sessions;
    dS+=Object.values(sub.sessions).filter(s=>sp(s)===3).length;
    nD+=st.notes;vD+=st.video;dbD+=st.doubts;
  }
  const pct=tA?Math.round(tD/tA*100):0;
  const cards=[
    {l:'Overall Progress',v:`${pct}%`,s:`${tD}/${tA} tasks`,c:'var(--accent)'},
    {l:'Sessions Complete',v:`${dS}`,s:`of ${tS} total`,c:'var(--done)'},
    {l:'Notes Done',v:`${nD}`,s:'sessions',c:'var(--notes)'},
    {l:'Videos Done',v:`${vD}`,s:'sessions',c:'var(--video)'},
    {l:'Doubts Done',v:`${dbD}`,s:'sessions',c:'var(--doubts)'},
    {l:'Pending Sessions',v:`${tS-dS}`,s:'need attention',c:'var(--accent2)'},
  ];
  document.getElementById('statGrid').innerHTML=cards.map(c=>`
    <div class="stat-card">
      <div class="stat-label">${c.l}</div>
      <div class="stat-val" style="color:${c.c}">${c.v}</div>
      <div class="stat-sub">${c.s}</div>
    </div>`).join('');
}

function renderSubjectBars(){
  const el=document.getElementById('subjectBars');el.innerHTML='';
  const entries=Object.entries(state.subjects).sort(([,a],[,b])=>sStat(b).pct-sStat(a).pct);
  for(const[name,sub]of entries){
    const st=sStat(sub);if(!st.sessions)continue;
    const nP=Math.round(st.notes/st.sessions*100);
    const vP=Math.round(st.video/st.sessions*100);
