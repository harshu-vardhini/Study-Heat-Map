// ── TRACKER ─────────────────────────────────────────────────────────────────
function renderTracker(){
  const fSub=document.getElementById('fSub').value;
  const fStatus=document.getElementById('fStatus').value;
  const search=document.getElementById('fSearch').value.toLowerCase();
  const sel=document.getElementById('fSub');const cur=sel.value;
  sel.innerHTML='<option value="">All Subjects</option>';
  for(const name of Object.keys(state.subjects)){const o=document.createElement('option');o.value=name;o.textContent=name;if(name===cur)o.selected=true;sel.appendChild(o);}
  const grid=document.getElementById('sGrid');grid.innerHTML='';
  let tD=0,tA=0;
  for(const[name,sub]of Object.entries(state.subjects)){
    if(fSub&&name!==fSub)continue;
    const st=sStat(sub);tD+=st.done;tA+=st.total;
    let sessions=Object.entries(sub.sessions);
    if(search)sessions=sessions.filter(([d])=>d.toLowerCase().includes(search));
    if(fStatus==='complete')sessions=sessions.filter(([,s])=>sp(s)===3);
    else if(fStatus==='partial')sessions=sessions.filter(([,s])=>{const p=sp(s);return p>0&&p<3;});
    else if(fStatus==='pending')sessions=sessions.filter(([,s])=>sp(s)===0);
    if((fStatus||search)&&sessions.length===0)continue;
    const sorted=sessions.sort(([a],[b])=>pdk(a)-pdk(b));
    const nP=st.sessions?st.notes/st.sessions*100:0;
    const vP=st.sessions?st.video/st.sessions*100:0;
    const dP=st.sessions?st.doubts/st.sessions*100:0;
    const card=document.createElement('div');
    card.className='subject-card'+(sub.collapsed?' collapsed':'');
    card.innerHTML=`
      <div class="card-hdr" onclick="toggleCollapse('${esc(name)}')">
        <div class="card-dot" style="background:${sub.color}"></div>
        <div class="card-name">${name}</div>
        <div class="card-meta">${Object.values(sub.sessions).filter(s=>sp(s)===3).length}/${Object.keys(sub.sessions).length} done · ${st.pct}%</div>
        <div class="card-tog">▾</div>
      </div>
      <div class="card-bar">
        <div class="card-seg" style="width:${nP/3}%;background:var(--notes);opacity:.75;"></div>
        <div class="card-seg" style="width:${vP/3}%;background:var(--video);opacity:.75;"></div>
        <div class="card-seg" style="width:${dP/3}%;background:var(--doubts);opacity:.75;"></div>
      </div>
      <div class="sess-list" id="sl-${esc(name)}"></div>
      <div class="add-row">
        <input placeholder="Add date, e.g. 15/04 or 15/04 (tag)" id="ai-${esc(name)}">
        <button class="btn btn-ghost" style="font-size:.6rem;padding:4px 8px;" onclick="quickAdd('${esc(name)}')">+ Add</button>
      </div>`;
    grid.appendChild(card);
    const list=card.querySelector('.sess-list');
    for(const[dk,sess]of sorted){
      const p=sp(sess);const row=document.createElement('div');
      row.className='sess-row'+(p===3?' all-done':'');
      const snip=sess.sessionNote?`<span class="sess-snip" title="${sess.sessionNote}" onclick="openNote(event,'${esc(name)}','${enc(dk)}')">${sess.sessionNote}</span>`:'';
      row.innerHTML=`
        <div class="sess-date">${dk}${snip}</div>
        <button class="chk ${sess.notes?'on':''}" data-t="notes" onclick="toggle('${esc(name)}','${enc(dk)}','notes',this)">📝<span class="tip">Notes Done</span></button>
        <button class="chk ${sess.video?'on':''}" data-t="video" onclick="toggle('${esc(name)}','${enc(dk)}','video',this)">▶<span class="tip">Video Done</span></button>
        <button class="chk ${sess.doubts?'on':''}" data-t="doubts" onclick="toggle('${esc(name)}','${enc(dk)}','doubts',this)">❓<span class="tip">Doubts Done</span></button>
        <div class="sact">
          <button class="ico" onclick="openNote(event,'${esc(name)}','${enc(dk)}')" title="Note">✎</button>
          <button class="ico del" onclick="delSession('${esc(name)}','${enc(dk)}')" title="Delete">✕</button>
        </div>`;
      list.appendChild(row);
    }
  }
  const pct=tA?Math.round(tD/tA*100):0;
  document.getElementById('overallTag').innerHTML=`Overall: <b>${pct}%</b> (${tD}/${tA})`;
}

// ── INTERACTIONS ─────────────────────────────────────────────────────────────
function toggle(subEsc,dateEsc,field,btn){
  const sn=byEsc(subEsc),dk=dec(dateEsc),sess=state.subjects[sn].sessions[dk];
  sess[field]=!sess[field];btn.classList.toggle('on',sess[field]);
  const row=btn.closest('.sess-row');if(row)row.classList.toggle('all-done',sp(sess)===3);
  saveData();updatePills();buildSubNav();
  if(activeView==='analytics')renderAnalytics();
  // update card bar & meta
  const card=btn.closest('.subject-card');
  if(card){
    const sub=state.subjects[sn],st=sStat(sub);
    const meta=card.querySelector('.card-meta');if(meta)meta.textContent=`${Object.values(sub.sessions).filter(s=>sp(s)===3).length}/${Object.keys(sub.sessions).length} done · ${st.pct}%`;
    const segs=card.querySelectorAll('.card-seg');
    if(segs[0])segs[0].style.width=`${st.sessions?st.notes/st.sessions*100/3:0}%`;
    if(segs[1])segs[1].style.width=`${st.sessions?st.video/st.sessions*100/3:0}%`;
    if(segs[2])segs[2].style.width=`${st.sessions?st.doubts/st.sessions*100/3:0}%`;
  }
}
function toggleCollapse(subEsc){const sn=byEsc(subEsc);state.subjects[sn].collapsed=!state.subjects[sn].collapsed;renderTracker();}
function collapseAll(){for(const s of Object.values(state.subjects))s.collapsed=true;renderTracker();}
function expandAll(){for(const s of Object.values(state.subjects))s.collapsed=false;renderTracker();}
function quickAdd(subEsc){
  const sn=byEsc(subEsc),inp=document.getElementById('ai-'+subEsc),val=inp.value.trim();
  if(!val)return;if(state.subjects[sn].sessions[val]){showToast('Already exists');return;}
  state.subjects[sn].sessions[val]={notes:false,video:false,doubts:false,sessionNote:''};
  saveData();renderTracker();buildSubNav();updatePills();showToast('Session added ✓');
}
function openNote(e,subEsc,dateEsc){
  e.stopPropagation();const sn=byEsc(subEsc),dk=dec(dateEsc);noteCtx={sn,dk};
  document.getElementById('noteTitle').textContent=`${sn} · ${dk}`;
  document.getElementById('noteText').value=state.subjects[sn].sessions[dk].sessionNote||'';
  document.getElementById('noteModal').classList.add('open');
}
function saveNote(){
  const{sn,dk}=noteCtx;state.subjects[sn].sessions[dk].sessionNote=document.getElementById('noteText').value;
  closeModal('noteModal');saveData();renderTracker();
}
function delSession(subEsc,dateEsc){
  const sn=byEsc(subEsc),dk=dec(dateEsc);
  if(!confirm(`Delete "${dk}" from ${sn}?`))return;
  delete state.subjects[sn].sessions[dk];
  saveData();renderTracker();buildSubNav();updatePills();
  if(activeView==='analytics')renderAnalytics();showToast('Deleted');
}
function openAddSubject(){document.getElementById('addSubModal').classList.add('open');}
function addSubject(){
  const name=document.getElementById('nSubName').value.trim();
  const color=document.getElementById('nSubColor').value;
  const raw=document.getElementById('nSubDates').value.trim();
  if(!name){showToast('Enter subject name');return;}
  if(!state.subjects[name])state.subjects[name]={color,collapsed:false,sessions:{}};
  if(raw)for(const l of raw.split('\n')){const d=l.trim();if(d&&!state.subjects[name].sessions[d])state.subjects[name].sessions[d]={notes:false,video:false,doubts:false,sessionNote:''};}
  closeModal('addSubModal');document.getElementById('nSubName').value='';document.getElementById('nSubDates').value='';
  saveData();buildSubNav();updatePills();
  if(activeView==='tracker')renderTracker();else renderAnalytics();
  showToast('Subject added ✓');
}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(el=>el.addEventListener('click',e=>{if(e.target===el)closeModal(el.id);}));

// CSV
function exportCSV(){
  const rows=[['Subject','Date/Session','Notes Done','Video Done','Doubts Done','Session Note']];
  for(const[n,sub]of Object.entries(state.subjects))
    for(const[dk,sess]of Object.entries(sub.sessions))
      rows.push([n,dk,sess.notes?'Yes':'No',sess.video?'Yes':'No',sess.doubts?'Yes':'No',sess.sessionNote||'']);
  const csv=rows.map(r=>r.map(c=>`"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download=`upsc_tracker_${new Date().toISOString().slice(0,10)}.csv`;a.click();showToast('CSV downloaded ✓');
}
function triggerImport(){document.getElementById('csvFile').click();}
function handleImport(e){const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>importCSV(ev.target.result);r.readAsText(f);e.target.value='';}
function importCSV(text){
  for(const line of text.split('\n').slice(1)){
    if(!line.trim())continue;
    const parts=line.match(/("(?:[^"]|"")*"|[^,]+)(?:,|$)/g);if(!parts||parts.length<5)continue;
    const c=parts.map(p=>p.replace(/,$/,'').replace(/^"|"$/g,'').replace(/""/g,'"'));
    const[subj,dk,notes,video,doubts,note=''] = c;
    if(!state.subjects[subj])continue;
    if(!state.subjects[subj].sessions[dk])state.subjects[subj].sessions[dk]={notes:false,video:false,doubts:false,sessionNote:''};
    state.subjects[subj].sessions[dk].notes=notes==='Yes';
    state.subjects[subj].sessions[dk].video=video==='Yes';
    state.subjects[subj].sessions[dk].doubts=doubts==='Yes';
    state.subjects[subj].sessions[dk].sessionNote=note;
  }
  saveData();buildSubNav();updatePills();
  if(activeView==='analytics')renderAnalytics();else renderTracker();showToast('CSV imported ✓');
}
document.addEventListener('dragover',e=>e.preventDefault());
document.addEventListener('drop',e=>{
  e.preventDefault();const f=e.dataTransfer.files[0];
  if(!f||!f.name.endsWith('.csv')){showToast('Drop a .csv file');return;}
  const r=new FileReader();r.onload=ev=>importCSV(ev.target.result);r.readAsText(f);
});

// TOAST
let tt;
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(tt);tt=setTimeout(()=>t.classList.remove('show'),2200);}

// BOOT
initState();buildSubNav();updatePills();renderAnalytics();
</script>
</body>
</html>
